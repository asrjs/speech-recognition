{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@asrjs/speech-recognition": ["./src/index.ts"],
      "@asrjs/speech-recognition/builtins": ["./src/builtins.ts"],
      "@asrjs/speech-recognition/io": ["./src/io.ts"],
      "@asrjs/speech-recognition/inference": ["./src/inference.ts"],
      "@asrjs/speech-recognition/browser": ["./src/browser.ts"],
      "@asrjs/speech-recognition/realtime": ["./src/realtime.ts"],
      "@asrjs/speech-recognition/bench": ["./src/bench.ts"],
      "@asrjs/speech-recognition/datasets": ["./src/datasets.ts"],
      "@asrjs/speech-recognition/models/*": ["./src/models/*.ts"],
      "@asrjs/speech-recognition/presets/*": ["./src/presets/*.ts"]
    }
  },
  "include": ["examples/**/*.ts"],
  "exclude": []
}
